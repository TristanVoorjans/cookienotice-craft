<section id="cookiebanner" class="cookiebanner hidden" aria-labelledby="accept-cookiebanner" role="dialog"
    aria-modal="true" tabindex="-1">
    <div class="cookiebanner-content">
        <div class="cookiebanner-body">
            <h2 id="accept-cookiebanner" class="cookiebanner-headline">
                {{ 'Onze website gebruikt cookies'|t('cookie-notice') }}
            </h2>
            <p>
                {{ 'Hallo, onze website maakt gebruik van cookies om de goede werking ervan te garanderen.
                Daarom kun je de essentiële en functionele cookies niet weigeren. Andere cookies worden enkel
                geplaatst met jouw toestemming. Door op \'Cookies aanvaarden\' te klikken ga je akkoord met het
                opslaan van alle cookies op jouw computer. Door op \'Cookies instellen\' te klikken kan je kiezen welke
                cookies je toelaat.'|t('cookie-notice') }}
            </p>
        </div>
        <div class="cookiebanner-actions">
            <button class="button button--primary js-cookie-accept notranslate">
                {{ 'Cookies aanvaarden'|t('cookie-notice') }}
            </button>
            <button class="cookiebanner-link js-cookie-essentials notranslate">
                {{ 'Enkel essentiële cookies aanvaarden'|t('cookie-notice') }}
            </button>
            <button class="cookiebanner-link js-cookie-settings notranslate">
                {{ 'Cookies instellen'|t('cookie-notice') }}
            </button>
        </div>
    </div>
</section>